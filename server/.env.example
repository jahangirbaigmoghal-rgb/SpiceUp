# TakeawayPOS Pro — Environment Variables
# Copy to .env.local and fill in your values

# Server
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:3000
POS_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002
KDS_URL=http://localhost:3003

# Database
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/takeaway_pos
# Set to 'true' for local dev without MongoDB Atlas:
# USE_MEMORY_DB=true

# Redis (Upstash)
REDIS_URL=redis://default:PASSWORD@REGION.upstash.io:6379

# Auth
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=8h
COOKIE_SECRET=your-cookie-signing-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+447...

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# Voice Agent (internal API key)
VOICE_AGENT_API_KEY=your-voice-agent-internal-key
VOICE_AGENT_URL=http://localhost:8000

# Printer (Epson TM-T88 network printer)
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9100

# Email (SendGrid SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG...
EMAIL_FROM=orders@yourrestaurant.co.uk

# Tenant (populated after first seed run)
DEFAULT_TENANT_ID=
