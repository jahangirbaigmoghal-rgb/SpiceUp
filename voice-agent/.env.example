# =========================================================================
# SpiceUp Voice Agent - Environment Variables Template
# Copy this file to .env and fill in your actual credentials.
# =========================================================================

# Google Gemini API Settings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Charon # Male UK Voice

# Twilio Credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+441782288662

# POS Backend Integration Settings
BACKEND_URL=http://localhost:5001
VOICE_AGENT_API_KEY=your_voice_agent_api_key_here

# MongoDB Settings (for storing call logs and customer lookup)
MONGODB_URI=mongodb://localhost:27017/spiceup

# Restaurant Details
RESTAURANT_NAME=Rupeyal Express
RESTAURANT_PHONE=+441782288662

# Voice Agent Server Settings
HOST=0.0.0.0
PORT=5050

# Recording Settings
ENABLE_RECORDING=True
RECORDING_CONSENT_MESSAGE=Please note that this call is recorded for quality assurance and training.

# AWS S3 Configuration (Optional - for archiving recordings outside MongoDB)
# S3_BUCKET_NAME=your_s3_bucket_name_here
# AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
